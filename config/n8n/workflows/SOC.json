    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $json.body || {};\nconst raw = body.raw || {};\nconst rule = raw.rule || {};\nconst agent = raw.agent || {};\n\nconst rule_id = body.rule_id || rule.id || '';\nconst rule_description = body.rule_description || rule.description || '';\nconst agent_name = body.agent_name || agent.name || '';\nconst agent_id = body.agent_id || agent.id || '';\nconst src_ip = body.src_ip || '';\nconst full_log = body.full_log || '';\n\nconst summary_for_llm = `\nRègle: ${rule_id}\nDescription: ${rule_description}\nAgent: ${agent_name} (${agent_id})\nIP source: ${src_ip || 'N/A'}\nLog brut: ${full_log}\n`.trim();\n\nreturn {\n  rule_id,\n  rule_description,\n  agent_name,\n  agent_id,\n  src_ip,\n  full_log,\n  summary_for_llm,\n  raw,\n};"
      },
